{
  "rules": {
    "messages": {
      "$chatId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".validate": "newData.hasChildren(['senderId', 'text', 'type', 'createdAt']) && newData.child('senderId').val() === auth.uid",
          ".write": "auth != null && (!data.exists() || data.child('senderId').val() === auth.uid)"
        }
      }
    },
    "chatParticipants": {
      "$chatId": {
        ".read": "auth != null && data.child(auth.uid).exists()",
        ".write": false
      }
    }
  }
}
