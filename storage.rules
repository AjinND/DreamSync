rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
             && firestore.exists(/databases/(default)/documents/chats/$(chatId))
             && firestore.get(/databases/(default)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
    }

    // Profile avatars: public read, only owner can write
    // Moved to /avatars/ path for public discoverability
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    // Legacy profile images path (for backwards compatibility)
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    // Public dream images: anyone can read, only owner can write
    match /public_dreams/{userId}/{dreamId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 10 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    // Private dream images: only owner can read/write
    match /dreams/{userId}/{dreamId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 10 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    // Chat assets (group photo + message media): participant read, scoped write.
    match /chats/{chatId}/group.jpg {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId)
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    match /chats/{chatId}/messages/{userId}/{fileName} {
      allow read: if isChatParticipant(chatId);
      allow write: if isChatParticipant(chatId)
                   && request.auth.uid == userId
                   && (
                     request.resource == null ||
                     (
                       request.resource.size < 5 * 1024 * 1024 &&
                       request.resource.contentType.matches('image/.*')
                     )
                   );
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
